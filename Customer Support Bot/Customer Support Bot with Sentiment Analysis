      "parameters": {
        "jsCode": "// N8N Code Node - Extract email and clean message from Gmail JSON\nconst data = $input.first().json;\n\n// Function to extract email from \"Name <email>\" format\nfunction extractEmail(fromField) {\n  const match = fromField.match(/<(.+?)>/);\n  return match ? match[1] : fromField;\n}\n\n// Function to extract clean message from snippet\nfunction extractMessage(snippet) {\n  // Split by common email reply patterns and take the first part\n  let message = snippet.split(' On ')[0];\n  message = message.split('&lt;')[0];\n  message = message.split('--')[0];\n  return message.trim();\n}\n\nconst result = [];\n\n// Check if data exists and has the expected structure\nif (data && Array.isArray(data) && data.length > 0 && data[0].messages) {\n  // Process each message in the thread\n  data[0].messages.forEach(message => {\n    result.push({\n      mail: extractEmail(message.From),\n      message: extractMessage(message.snippet)\n    });\n  });\n} else if (data && data.messages) {\n  // Handle case where data is directly the object (not in array)\n  data.messages.forEach(message => {\n    result.push({\n      mail: extractEmail(message.From),\n      message: extractMessage(message.snippet)\n    });\n  });\n}\n\nreturn result;"
      },
